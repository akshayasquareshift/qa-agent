# ─── Auth (two modes) ────────────────────────────────────────────────────────
# The AI client is dual-mode:
#
#  1. API key (recommended for servers / cloud / GCP — no interactive login):
#       ANTHROPIC_API_KEY=sk-ant-...
#     When this is set, the agent calls the Anthropic Messages API directly
#     (billed per-token). This is the mode to use in a headless container.
#
#  2. Claude Code CLI (default for local dev — no API key):
#     If ANTHROPIC_API_KEY is NOT set, the agent shells out to the `claude` CLI
#     using your existing `claude login`. Calls count against your Claude
#     Pro/Max subscription. Requires the `claude` binary on PATH.
#
# ANTHROPIC_API_KEY=sk-ant-...
#
# Optional overrides (both modes):
# ANTHROPIC_MODEL=claude-opus-4-8    # default model (API mode also accepts aliases opus/sonnet/haiku)
# CLAUDE_BIN=/usr/local/bin/claude   # CLI mode only — if `claude` is not on PATH

# ─── Application under test ──────────────────────────────────────────────────
# URL of the running application — local OR cloud-hosted (any http/https URL)
BASE_URL=http://localhost:3000

# ─── Source code: local paths OR a GitHub repo ───────────────────────────────
# The agent reads your app's routes + selectors from its SOURCE CODE. You can
# point it at a local checkout (default) or have it fetch a GitHub repo for you.
#
# Option A — local source (default): set absolute paths.
# Option B — GitHub source: set APP_REPO_URL below; then APP_SOURCE_DIR and
#            APP_MODULES_DIR are interpreted as paths RELATIVE TO THE REPO ROOT
#            (e.g. "src/app" / "src/modules"). Requires `git` on PATH.
#
# APP_REPO_URL=https://github.com/your-org/your-app
# APP_REPO_BRANCH=main          # optional; defaults to the repo's default branch
# APP_REPO_REFRESH=true         # optional; "false" reuses the cached clone
# GITHUB_TOKEN=ghp_xxx          # optional; only for PRIVATE github.com repos

# Path to the app's router / pages dir  (absolute, or repo-relative if APP_REPO_URL is set)
APP_SOURCE_DIR=/absolute/path/to/your-app/src

# Path to the components dir (scanned for data-testid attributes + button labels)
# (absolute, or repo-relative if APP_REPO_URL is set)
APP_MODULES_DIR=/absolute/path/to/your-app/src/components

# Optional: path to the app's package.json (used for framework detection)
# APP_PACKAGE_JSON=/absolute/path/to/your-app/package.json

# ─── Test credentials (used in generated auth setup steps) ───────────────────
# Create a dedicated test account in your app and set the credentials here.
# These are injected into every spec that requires authentication.
#
# AUTO-REGISTRATION: If your app exposes a register/signup route, the agent's
# Phase 1.5 "Auth Bootstrap" will create a fresh user and OVERWRITE the values
# below with the seeded credentials (TEST_USERNAME, TEST_PASSWORD, TEST_EMAIL).
# To opt out: set TEST_USERNAME to a real account (anything other than the
# placeholder below). To force re-registration on every run: FORCE_REGISTER=true.
TEST_USERNAME=your_test_username
TEST_PASSWORD=your_test_password
# TEST_EMAIL — written by the bootstrap; not required up front
# FORCE_REGISTER=true

# ─── Optional ────────────────────────────────────────────────────────────────
# Locale/region prefix used in URLs (leave empty if your app has no locale segment)
COUNTRY_CODE=

# Comma-separated test record identifiers seeded in your database
# Works for any app — not just e-commerce (e.g. patient IDs, report slugs, user handles)
# SEED_DATA=record-001,patient-001,doctor-abc

# Display name shown in the coverage report
APP_NAME=My Application

# Maximum AI fix rounds per failing test (default: 3)
MAX_FIX_ROUNDS=3

# ─── Pre-flight checks ───────────────────────────────────────────────────────
# Before generating, the agent (1) warns if the analysed source doesn't seem to
# match the app at BASE_URL (discovered routes 404), and (2) runs a one-off
# "auth smoke test" to confirm login works (a broken login fails every
# auth-gated test). Both are on by default.
# SKIP_RECON_CHECK=true   # disable the source↔app reachability check
# SKIP_AUTH_SMOKE=true    # disable the pre-generation login smoke test
# STRICT_AUTH=true        # abort the run if the auth smoke test fails (default: warn + continue)
