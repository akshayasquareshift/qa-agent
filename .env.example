# ─── Required ────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# ─── Application under test ──────────────────────────────────────────────────
# URL of the running application
BASE_URL=http://localhost:3000

# Absolute path to the app router / pages directory (Next.js: src/app or pages/)
APP_SOURCE_DIR=/absolute/path/to/your-app/src/app

# Absolute path to the components / modules directory (for data-testid scanning)
APP_MODULES_DIR=/absolute/path/to/your-app/src/components

# Optional: path to the app's package.json (used for framework detection)
# APP_PACKAGE_JSON=/absolute/path/to/your-app/package.json

# ─── Optional ────────────────────────────────────────────────────────────────
# Locale/region prefix used in URLs (leave empty if your app has no locale segment)
COUNTRY_CODE=

# Comma-separated product/item slugs seeded in your test database
# PRODUCT_HANDLES=t-shirt,sweatshirt,jeans

# Display name shown in the coverage report
APP_NAME=My Application

# Maximum AI fix rounds per failing test (default: 3)
MAX_FIX_ROUNDS=3
