{
  "name": "qa-agent",
  "version": "1.0.0",
  "private": true,
  "description": "Autonomous AI-powered QA agent — generates, runs, and self-heals Playwright E2E tests for any web application",
  "pnpm": {
    "onlyBuiltDependencies": ["esbuild"]
  },
  "scripts": {
    "generate": "pnpm --filter @qa/agents run generate",
    "plan-only": "pnpm --filter @qa/agents run plan-only",
    "author": "pnpm --filter @qa/agents run author",
    "heal": "pnpm --filter @qa/healer run heal",
    "heal:demo": "pnpm --filter @qa/healer run heal:demo",
    "install:browsers": "npx playwright install chromium"
  }
}
